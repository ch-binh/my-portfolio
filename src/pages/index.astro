---
import Layout from '../layouts/Layout.astro';

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
---

<Layout title="Binh Pham - Embedded Firmware Engineer" wide dark>
  <section class="landing">
    <div class="copy">
      <p class="status"><span></span> Embedded systems / signal online</p>
      <p class="role">Firmware engineer</p>
      <h1>
        <span class="greeting">Hi, I'm</span>
        <span class="signature">Binh Pham</span>
      </h1>
      <p class="intro">
        I build reliable embedded firmware for real-time systems, sensors, storage, and digital audio.
      </p>
      <div class="links">
        <a href={`${baseUrl}projects/`}>View projects</a>
        <a href={`${baseUrl}contact/`}>Contact</a>
      </div>
    </div>

    <div class="signal" aria-hidden="true">
      <div class="ring"></div>
      <div class="core"></div>
    </div>
  </section>
</Layout>

<style>
  :global(.container.wide header) {
    margin-bottom: 0;
    padding: 1.15rem 0;
    border-bottom: 1px solid rgba(139, 152, 165, 0.14);
  }

  :global(.container.wide footer) {
    display: none;
  }

  :global(.container.wide) {
    padding-bottom: 0;
  }

  .landing {
    position: relative;
    min-height: calc(100vh - 92px);
    margin: 0;
    padding: clamp(4rem, 10vh, 7.5rem) 0 4rem;
    border: 0;
    border-radius: 0;
    background: transparent;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .landing:hover {
    transform: none;
    border-color: transparent;
    box-shadow: none;
  }

  .copy {
    position: relative;
    z-index: 1;
  }

  .status {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--text-muted);
    font: 0.7rem 'JetBrains Mono', monospace;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    margin-bottom: clamp(3.5rem, 9vh, 6rem);
  }

  .status span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-color);
    box-shadow: 0 0 12px rgba(120, 220, 232, 0.8);
    animation: pulse 2.6s ease-in-out infinite;
  }

  .role {
    color: var(--accent-color);
    font: 500 0.73rem 'JetBrains Mono', monospace;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 1.3rem;
  }

  h1 {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    font-size: clamp(3.5rem, 8.7vw, 7.8rem);
    line-height: 0.94;
    letter-spacing: -0.072em;
    font-weight: 500;
    margin: 0 0 2.35rem;
  }

  .greeting {
    color: var(--text-color);
  }

  .signature {
    position: relative;
    display: inline-block;
    padding: 0 0 clamp(0.35rem, 1vw, 0.72rem);
    color: transparent;
    background: linear-gradient(103deg, #e6edf3 0%, #78dce8 48%, #8aa4ff 100%);
    background-clip: text;
    -webkit-background-clip: text;
  }

  .signature::after {
    content: "";
    position: absolute;
    left: 0.07em;
    bottom: 0;
    width: min(48%, 3.4em);
    height: 1px;
    background: linear-gradient(90deg, var(--accent-color), transparent);
  }

  .intro {
    max-width: 490px;
    color: var(--text-muted);
    font-size: clamp(1rem, 1.4vw, 1.08rem);
    line-height: 1.72;
    margin-bottom: 2.8rem;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .links a {
    color: var(--text-color);
    font: 500 0.83rem 'JetBrains Mono', monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-bottom: 0.45rem;
    border-bottom: 1px solid var(--border-color);
  }

  .links a:first-child {
    border-color: var(--accent-color);
  }

  .links a:hover {
    color: var(--accent-color);
    transform: none;
    border-color: var(--accent-color);
  }

  .signal {
    position: absolute;
    right: clamp(-10rem, 3vw, 1rem);
    top: 50%;
    transform: translateY(-50%);
    width: clamp(285px, 41vw, 530px);
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    opacity: 0.58;
  }

  .ring {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 1px solid rgba(120, 220, 232, 0.18);
    box-shadow: inset 0 0 70px rgba(120, 220, 232, 0.025);
  }

  .ring::after {
    content: "";
    position: absolute;
    inset: 24%;
    border-radius: 50%;
    border: 1px solid rgba(120, 220, 232, 0.1);
  }

  .core {
    position: absolute;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent-color);
    box-shadow: 0 0 25px var(--accent-color);
  }

  @keyframes pulse {
    50% { opacity: 0.32; }
  }

  @media (max-width: 760px) {
    .landing {
      min-height: calc(100vh - 82px);
      align-items: flex-start;
    }

    .status {
      margin-bottom: 3.4rem;
    }

    .signal {
      right: -190px;
      bottom: -50px;
      top: auto;
      transform: none;
      opacity: 0.28;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .status span {
      animation: none;
    }
  }
</style>
