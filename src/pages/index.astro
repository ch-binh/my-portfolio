---
import Layout from '../layouts/Layout.astro';
const name = "Binh Pham";

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
---

<Layout title="Binh Pham - Embedded Systems & Firmware Consultant">
  <!-- Spotlight Effect in Hero Background -->
  <div class="hero-spotlight"></div>

  <!-- Hero Section (Two-Column Grid) -->
  <div class="hero-section">
    <div class="hero-grid">
      <!-- Left Column: Bio Details -->
      <div class="hero-details">
        <div class="mascot-container">
          <img 
            src={`${baseUrl}linh_vat.png`} 
            alt="Saki Mascot" 
            class="mascot-avatar"
          />
        </div>
        <h1 class="greeting">
          Hi, I'm <span class="name-gradient">{name}</span> <span class="led-pulse">//</span>
        </h1>
        <p class="role-title">Embedded Firmware & Systems Engineer</p>
        <p class="bio-intro">
          I build and debug firmware for Cortex-M systems (STM32, nRF52), focusing on low-level peripheral drivers (SPI, I2C, UART, SDMMC, DMA), RTOS task scheduling, and hardware-to-software integration.
        </p>
        <p class="bio-intro availability">
          ⚡ Available for technical consulting, custom driver development, and system integration.
        </p>
      </div>

      <!-- Right Column: Visual Prototyping Setup -->
      <div class="hero-visual">
        <div class="image-wrapper">
          <img 
            src={`${baseUrl}hardware_hero.png`} 
            alt="STM32 hardware prototyping board under spotlight" 
            class="hardware-hero-img"
          />
          <div class="image-glow"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Freelance Services -->
  <div class="section-block services-section">
    <h2 class="serif-header">💼 How I Can Help Your Product</h2>
    <div class="services-grid">
      <div class="service-card">
        <h3>🔌 Custom Driver Development</h3>
        <p>Interfacing specialized sensors, displays, or storage devices via SPI, I2C, UART, SDMMC, and custom register-level configurations.</p>
      </div>
      <div class="service-card">
        <h3>⚙️ RTOS & Multi-threaded Architecture</h3>
        <p>Designing stable, low-latency firmware architectures using FreeRTOS or Zephyr to ensure thread safety and avoid race conditions.</p>
      </div>
      <div class="service-card">
        <h3>🎙️ Audio & Sensor Signal Processing</h3>
        <p>High-precision digital audio capturing (PDM/I2S) and sensor filtering (Kalman, SMA) to clean up raw measurement data.</p>
      </div>
    </div>
  </div>

  <!-- Tech Stack Grid -->
  <div class="section-block stack-section">
    <h2 class="serif-header">🛠️ Core Stack</h2>
    <div class="badge-grid">
      <span class="badge">C / C++</span>
      <span class="badge">Golang</span>
      <span class="badge">FreeRTOS</span>
      <span class="badge">Zephyr RTOS</span>
      <span class="badge">Embedded Linux</span>
      <span class="badge">Yocto Project</span>
      <span class="badge">DMA & Peripherals</span>
      <span class="badge">TCP/IP & BLE</span>
      <span class="badge">GDB & J-Link</span>
      <span class="badge">Saleae Logic</span>
    </div>
  </div>

  <!-- Quick Nav (CTA) -->
  <div class="section-block cta-section">
    <h2 class="serif-header">📂 Explore My Work</h2>
    <div class="cta-grid">
      <a href={`${baseUrl}projects/`} class="cta-card">
        <h3>Projects →</h3>
        <p>Graduation thesis, HX711 Loadcell, nRF52 PDM Audio, and STM32 DMA debugging journals.</p>
      </a>
      <a href={`${baseUrl}blog/`} class="cta-card">
        <h3>Blog Logs →</h3>
        <p>Technical diaries on PDM-to-PCM conversion and digital Kalman noise filtering in C.</p>
      </a>
    </div>
  </div>

  <!-- Warm Get in Touch -->
  <div class="section-block contact-section">
    <h2 class="serif-header">✉️ Let's Connect</h2>
    <p>Always open to discuss low-level debugging, RTOS task scheduling, or Embedded Linux driver development.</p>
    <div class="contact-links">
      <a href="mailto:pcbinh.3005@gmail.com" class="contact-button">Email Me</a>
      <a href="https://github.com/ch-binh" target="_blank" rel="noopener noreferrer" class="contact-button">GitHub</a>
      <a href="https://www.linkedin.com/in/pham-chau-binh/" target="_blank" rel="noopener noreferrer" class="contact-button">LinkedIn</a>
    </div>
  </div>
</Layout>

<style>
  /* Hero Spotlight Background */
  .hero-spotlight {
    position: absolute;
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 350px;
    background: radial-gradient(
      ellipse at center,
      rgba(56, 189, 248, 0.05) 0%,
      rgba(11, 15, 25, 0) 70%
    );
    pointer-events: none;
    z-index: 0;
    animation: spotlight-breath 8s infinite ease-in-out;
  }

  @keyframes spotlight-breath {
    0%, 100% {
      opacity: 0.7;
      transform: translateX(-50%) scale(0.95);
    }
    50% {
      opacity: 1.2;
      transform: translateX(-50%) scale(1.05);
    }
  }

  /* Two-Column Hero Grid */
  .hero-section {
    position: relative;
    z-index: 1;
    margin-top: 1.5rem;
    margin-bottom: 4rem;
    animation: fade-in-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 2rem;
    align-items: center;
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  /* Mascot Avatar Styling */
  .mascot-container {
    margin-bottom: 1.25rem;
    display: inline-block;
    animation: fade-in-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .mascot-avatar {
    width: 88px;
    height: 88px;
    border-radius: 22px;
    object-fit: cover;
    border: 1px solid var(--border-color);
    box-shadow: 0 10px 25px -10px rgba(0, 0, 0, 0.6);
    transition: all 0.3s var(--ease-expo);
    background-color: #111827;
    display: block;
  }

  .mascot-container:hover .mascot-avatar {
    border-color: var(--accent-color);
    transform: translateY(-2px) scale(1.04);
    box-shadow: 0 12px 30px -10px rgba(56, 189, 248, 0.25);
  }

  .greeting {
    font-family: Georgia, 'Times New Roman', Times, serif;
    font-size: 2.75rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
    color: #ffffff;
  }

  .name-gradient {
    color: var(--accent-color);
    background: linear-gradient(to right, #38bdf8, #818cf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Pulsing LED Double Slash */
  .led-pulse {
    color: var(--accent-color);
    display: inline-block;
    animation: led-heartbeat 3s infinite ease-in-out;
  }

  @keyframes led-heartbeat {
    0%, 100% {
      opacity: 0.3;
      text-shadow: 0 0 2px rgba(56, 189, 248, 0);
    }
    50% {
      opacity: 1.0;
      text-shadow: 0 0 8px rgba(56, 189, 248, 0.5);
    }
  }

  .role-title {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--text-color);
    margin-bottom: 1.5rem;
  }

  .bio-intro {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 600px;
    margin-bottom: 0.75rem;
  }

  .bio-intro.availability {
    font-weight: 500;
    color: var(--accent-color);
    margin-top: 1rem;
    margin-bottom: 0;
  }

  /* Hero Visual styling (STM32 spotlight) */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .image-wrapper {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border-color);
    box-shadow: 0 15px 35px -15px rgba(0, 0, 0, 0.8);
    max-width: 280px;
    aspect-ratio: 4 / 3;
    transition: border-color 0.3s var(--ease-expo), box-shadow 0.3s var(--ease-expo);
  }

  .image-wrapper:hover {
    border-color: rgba(56, 189, 248, 0.3);
    box-shadow: 0 20px 40px -20px rgba(56, 189, 248, 0.25);
  }

  .hardware-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    animation: hardware-breath 8s infinite ease-in-out;
  }

  @keyframes hardware-breath {
    0%, 100% {
      filter: brightness(0.92) contrast(1.02);
      transform: scale(1.0);
    }
    50% {
      filter: brightness(1.03) contrast(0.98);
      transform: scale(1.02);
    }
  }

  .image-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(245, 158, 11, 0.04) 0%,
      rgba(11, 15, 25, 0) 70%
    );
    pointer-events: none;
    z-index: 2;
  }

  /* Elegant Serif Section Headers */
  .serif-header {
    font-family: Georgia, 'Times New Roman', Times, serif;
    font-size: 1.45rem !important;
    font-weight: 500 !important;
    letter-spacing: -0.01em !important;
    text-transform: none !important;
    color: #ffffff !important;
    border-bottom: 1px solid var(--border-color) !important;
    padding-bottom: 0.5rem !important;
    margin-bottom: 1.5rem !important;
  }

  /* Section Blocks with Cascading Animations */
  .section-block {
    margin-bottom: 4rem;
    opacity: 0;
    transform: translateY(15px);
  }

  .services-section {
    animation: fade-in-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.2s;
  }

  .stack-section {
    animation: fade-in-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.35s;
  }

  .cta-section {
    animation: fade-in-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.5s;
  }

  .contact-section {
    animation: fade-in-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.65s;
  }

  @keyframes fade-in-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Services Grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  .service-card {
    background-color: #111827;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.3s var(--ease-expo);
  }

  .service-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent-color);
    box-shadow: 0 10px 25px -12px rgba(56, 189, 248, 0.15);
  }

  .service-card h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
    color: #ffffff;
  }

  .service-card p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Badge Grid (Minimalist capsules) */
  .badge-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .badge {
    background-color: #111827;
    color: #f1f5f9;
    border: 1px solid var(--border-color);
    padding: 0.4rem 0.8rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s var(--ease-expo);
  }

  .badge:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px -4px rgba(56, 189, 248, 0.2);
  }

  /* CTA Grid (Quick navigation cards) */
  .cta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  @media (max-width: 600px) {
    .cta-grid {
      grid-template-columns: 1fr;
    }
  }

  .cta-card {
    background-color: #111827;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.3s var(--ease-expo);
    display: block;
    text-decoration: none;
  }

  .cta-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-color);
    box-shadow: 0 10px 25px -12px rgba(56, 189, 248, 0.15);
  }

  .cta-card h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: 1.15rem;
    color: #ffffff;
    transition: color 0.25s var(--ease-expo);
  }

  .cta-card:hover h3 {
    color: var(--accent-color);
  }

  .cta-card p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Contact Block */
  .contact-section p {
    color: var(--text-muted);
    font-size: 1rem;
    margin-bottom: 1.25rem;
  }

  .contact-links {
    display: flex;
    gap: 0.8rem;
  }

  .contact-button {
    background-color: #111827;
    color: #ffffff;
    border: 1px solid var(--border-color);
    padding: 0.5rem 1.2rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s var(--ease-expo);
    text-decoration: none;
  }

  .contact-button:hover {
    background-color: var(--accent-color);
    border-color: var(--accent-color);
    color: #0b0f19;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px -8px rgba(56, 189, 248, 0.3);
  }
</style>