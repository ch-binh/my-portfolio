---
import Layout from '../layouts/Layout.astro';

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
---

<Layout title="Binh Pham - Embedded Firmware Engineer" wide dark>
  <section class="landing">
    <div class="copy">
      <p class="status"><span></span> STM32 · nRF52 · FreeRTOS</p>
      <p class="role">Firmware engineer</p>
      <h1>
        <span class="greeting">Hi, I'm</span>
        <span class="signature">Binh Pham</span>
      </h1>
      <p class="intro">
        Embedded firmware engineer documenting low-level debugging, RTOS behavior, peripheral drivers, and hardware/software integration.
      </p>
      <div class="links">
        <a href={`${baseUrl}projects/`}>Projects</a>
        <a href={`${baseUrl}blog/`}>Notes</a>
        <a href="https://github.com/ch-binh" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </div>

    <div class="signal" aria-hidden="true">
      <div class="ring"></div>
      <div class="core"></div>
    </div>
  </section>

  <!-- What I Document Here -->
  <section class="doc-section">
    <h2 class="section-title">What I Document Here</h2>
    <div class="card-grid">
      <div class="doc-card">
        <span class="card-icon">🔍</span>
        <h3>Low-level Debugging</h3>
        <p>HardFaults, DMA issues, interrupt priority conflicts, cache coherence — the bugs that don't show up in tutorials.</p>
      </div>
      <div class="doc-card">
        <span class="card-icon">⏱️</span>
        <h3>RTOS & Scheduling</h3>
        <p>Task priorities, semaphore usage, context-switch behavior in FreeRTOS and Zephyr on real hardware.</p>
      </div>
      <div class="doc-card">
        <span class="card-icon">🔌</span>
        <h3>Peripheral Drivers</h3>
        <p>SPI, I2C, UART, SDMMC, PDM — writing and debugging drivers on STM32 and Nordic chips.</p>
      </div>
      <div class="doc-card">
        <span class="card-icon">🎛️</span>
        <h3>Audio & Sensor Work</h3>
        <p>PDM microphone capture, loadcell filtering, ADC noise reduction — signal processing on constrained MCUs.</p>
      </div>
    </div>
  </section>

  <!-- Recent Projects -->
  <section class="doc-section">
    <h2 class="section-title">Recent Projects</h2>
    <div class="project-list">
      <a href={`${baseUrl}projects/stm32-sdmmc-dma-debugging/`} class="project-item">
        <div class="project-meta">
          <span class="tag">STM32L4</span>
          <span class="tag">FreeRTOS</span>
          <span class="tag">DMA</span>
        </div>
        <h3>STM32 SDMMC + DMA Debugging</h3>
        <p>Debugging SD card write failures: NVIC priority inversion, D-Cache coherence, DMA FIFO underrun.</p>
      </a>
      <a href={`${baseUrl}projects/pdm-microphone-pcm-audio/`} class="project-item">
        <div class="project-meta">
          <span class="tag">nRF52</span>
          <span class="tag">PDM</span>
          <span class="tag">EasyDMA</span>
        </div>
        <h3>PDM Microphone to PCM Audio</h3>
        <p>Capture audio from PDM mic on nRF52, convert to 16-bit PCM with hardware decimation and double-buffering.</p>
      </a>
      <a href={`${baseUrl}projects/loadcell-weight-system/`} class="project-item">
        <div class="project-meta">
          <span class="tag">STM32</span>
          <span class="tag">HX711</span>
          <span class="tag">Kalman</span>
        </div>
        <h3>Loadcell Weight Measurement</h3>
        <p>Weight measurement with HX711 ADC. Kalman filter + moving average to reduce vibration noise.</p>
      </a>
    </div>
  </section>

  <!-- Latest Notes -->
  <section class="doc-section">
    <h2 class="section-title">Latest Notes</h2>
    <div class="notes-list">
      <a href={`${baseUrl}blog/calibrating-loadcells/`} class="note-item">
        <h3>Calibrating Loadcells: Digital Noise Filtering in Embedded C</h3>
        <p>Tare calibration, moving average, and 1D Kalman filter implementation on Cortex-M for stable weight readings.</p>
      </a>
      <a href={`${baseUrl}blog/pdm-vs-pcm/`} class="note-item">
        <h3>PDM vs PCM in Embedded Audio</h3>
        <p>Quick reference on what PDM and PCM are, and how they relate in embedded audio capture.</p>
      </a>
    </div>
  </section>
</Layout>

<style>
  :global(.container.wide header) {
    margin-bottom: 0;
    padding: 1.15rem 0;
    border-bottom: 1px solid rgba(139, 152, 165, 0.14);
  }

  :global(.container.wide footer) {
    display: none;
  }

  :global(.container.wide) {
    padding-bottom: 0;
  }

  .landing {
    position: relative;
    min-height: calc(100vh - 92px);
    margin: 0;
    padding: clamp(4rem, 10vh, 7.5rem) 0 4rem;
    border: 0;
    border-radius: 0;
    background: transparent;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .landing:hover {
    transform: none;
    border-color: transparent;
    box-shadow: none;
  }

  .copy {
    position: relative;
    z-index: 1;
  }

  .status {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--text-muted);
    font: 0.7rem 'JetBrains Mono', monospace;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    margin-bottom: clamp(3.5rem, 9vh, 6rem);
  }

  .status span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-color);
    box-shadow: 0 0 12px rgba(120, 220, 232, 0.8);
    animation: pulse 2.6s ease-in-out infinite;
  }

  .role {
    color: var(--accent-color);
    font: 500 0.73rem 'JetBrains Mono', monospace;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 1.3rem;
  }

  h1 {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    font-size: clamp(3.5rem, 8.7vw, 7.8rem);
    line-height: 0.94;
    letter-spacing: -0.072em;
    font-weight: 500;
    margin: 0 0 2.35rem;
  }

  .greeting {
    color: var(--text-color);
  }

  .signature {
    position: relative;
    display: inline-block;
    padding: 0 0 clamp(0.35rem, 1vw, 0.72rem);
    color: transparent;
    background: linear-gradient(103deg, #e6edf3 0%, #78dce8 48%, #8aa4ff 100%);
    background-clip: text;
    -webkit-background-clip: text;
  }

  .signature::after {
    content: "";
    position: absolute;
    left: 0.07em;
    bottom: 0;
    width: min(48%, 3.4em);
    height: 1px;
    background: linear-gradient(90deg, var(--accent-color), transparent);
  }

  .intro {
    max-width: 520px;
    color: var(--text-muted);
    font-size: clamp(1rem, 1.4vw, 1.08rem);
    line-height: 1.72;
    margin-bottom: 2.8rem;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .links a {
    color: var(--text-color);
    font: 500 0.83rem 'JetBrains Mono', monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-bottom: 0.45rem;
    border-bottom: 1px solid var(--border-color);
  }

  .links a:first-child {
    border-color: var(--accent-color);
  }

  .links a:hover {
    color: var(--accent-color);
    transform: none;
    border-color: var(--accent-color);
  }

  .signal {
    position: absolute;
    right: clamp(-10rem, 3vw, 1rem);
    top: 50%;
    transform: translateY(-50%);
    width: clamp(285px, 41vw, 530px);
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    opacity: 0.58;
  }

  .ring {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 1px solid rgba(120, 220, 232, 0.18);
    box-shadow: inset 0 0 70px rgba(120, 220, 232, 0.025);
  }

  .ring::after {
    content: "";
    position: absolute;
    inset: 24%;
    border-radius: 50%;
    border: 1px solid rgba(120, 220, 232, 0.1);
  }

  .core {
    position: absolute;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent-color);
    box-shadow: 0 0 25px var(--accent-color);
  }

  @keyframes pulse {
    50% { opacity: 0.32; }
  }

  /* === Below-the-fold sections === */

  .doc-section {
    margin: 0 auto;
    max-width: 960px;
    padding: 4rem 1.5rem;
    background: transparent;
    border: none;
    border-radius: 0;
    border-top: 1px solid rgba(139, 152, 165, 0.1);
  }

  .doc-section:hover {
    transform: none;
    border-color: rgba(139, 152, 165, 0.1);
    box-shadow: none;
  }

  .section-title {
    font: 500 0.72rem 'JetBrains Mono', monospace;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-color);
    margin: 0 0 2rem;
    border: none;
    padding: 0;
  }

  /* Card Grid */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .doc-card {
    padding: 1.4rem;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    background: var(--card-bg);
    transition: border-color 0.3s ease;
  }

  .doc-card:hover {
    border-color: var(--accent-color);
  }

  .card-icon {
    font-size: 1.3rem;
    display: block;
    margin-bottom: 0.7rem;
  }

  .doc-card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--text-color);
  }

  .doc-card p {
    font-size: 0.84rem;
    line-height: 1.6;
    color: var(--text-muted);
    margin: 0;
  }

  /* Project List */
  .project-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project-item {
    display: block;
    padding: 1.3rem 1.4rem;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    background: var(--card-bg);
    color: var(--text-color);
    transition: border-color 0.3s ease, transform 0.2s ease;
  }

  .project-item:hover {
    border-color: var(--accent-color);
    color: var(--text-color);
    transform: translateY(-2px);
  }

  .project-meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.7rem;
    flex-wrap: wrap;
  }

  .tag {
    font: 400 0.65rem 'JetBrains Mono', monospace;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    background: rgba(120, 220, 232, 0.08);
    color: var(--accent-color);
    border: 1px solid rgba(120, 220, 232, 0.15);
  }

  .project-item h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
    color: var(--text-color);
  }

  .project-item p {
    font-size: 0.84rem;
    line-height: 1.6;
    color: var(--text-muted);
    margin: 0;
  }

  /* Notes List */
  .notes-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .note-item {
    display: block;
    padding: 1.2rem 1.4rem;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    background: var(--card-bg);
    color: var(--text-color);
    transition: border-color 0.3s ease;
  }

  .note-item:hover {
    border-color: var(--accent-color);
    color: var(--text-color);
    transform: none;
  }

  .note-item h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 0.35rem;
    color: var(--text-color);
  }

  .note-item p {
    font-size: 0.84rem;
    line-height: 1.6;
    color: var(--text-muted);
    margin: 0;
  }

  @media (max-width: 760px) {
    .landing {
      min-height: calc(100vh - 82px);
      align-items: flex-start;
    }

    .status {
      margin-bottom: 3.4rem;
    }

    .signal {
      right: -190px;
      bottom: -50px;
      top: auto;
      transform: none;
      opacity: 0.28;
    }

    .card-grid {
      grid-template-columns: 1fr;
    }

    .doc-section {
      padding: 3rem 0.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .status span {
      animation: none;
    }
  }
</style>
