---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Me - Binh Pham Portfolio">
  <div class="about-page">
    <header class="intro">
      <p class="label">About</p>
      <h1>About Me</h1>
      <p class="lead">
        I am Binh Pham, an Embedded Firmware Engineer focused on reliable software
        where hardware signals, timing, and constrained resources matter.
      </p>
      <p class="supporting">
        My work centers on low-level drivers, real-time systems, DMA-based data paths,
        sensor processing, and digital audio on microcontrollers and embedded platforms.
      </p>
    </header>

    <section class="philosophy">
      <p class="label">Approach</p>
      <h2>Engineering Philosophy</h2>
      <div class="principles">
        <article>
          <h3>Observe First</h3>
          <p>I use traces, registers, logic analyzers, and debuggers to find root causes instead of guessing.</p>
        </article>
        <article>
          <h3>Design for Reliability</h3>
          <p>Firmware should be structured, defensive, and predictable under real hardware constraints.</p>
        </article>
        <article>
          <h3>Document Clearly</h3>
          <p>Technical decisions and debugging outcomes become useful when they are understandable to others.</p>
        </article>
      </div>
    </section>

    <section class="toolkit">
      <p class="label">Core toolkit</p>
      <h2>Systems I Work With</h2>
      <div class="tags">
        <span>C / C++</span>
        <span>STM32</span>
        <span>nRF52</span>
        <span>ESP32</span>
        <span>FreeRTOS</span>
        <span>Zephyr RTOS</span>
        <span>DMA / SDMMC</span>
        <span>PDM / I2S / PCM</span>
        <span>SPI / I2C / UART</span>
        <span>J-Link / GDB / Saleae</span>
      </div>
    </section>

    <section class="links">
      <div>
        <p class="label">Details</p>
        <h2>Profiles</h2>
      </div>
      <div class="actions">
        <a href="https://github.com/ch-binh" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://www.linkedin.com/in/pham-chau-binh/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .about-page {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .label {
    font: 500 0.72rem 'JetBrains Mono', monospace;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-color);
    margin-bottom: 0.7rem;
  }

  .intro h1 {
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1.13rem;
    line-height: 1.7;
    margin-bottom: 0.85rem;
  }

  .supporting {
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .about-page section {
    margin: 0;
    padding: 2rem;
    background: var(--card-bg);
  }

  .about-page section h2 {
    margin: 0 0 1.35rem;
    border: 0;
    padding: 0;
    font-size: 1.4rem;
  }

  .principles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .principles article {
    padding: 1.05rem;
    border-radius: 9px;
    background: var(--code-inline-bg);
    border: 1px solid var(--border-color);
  }

  .principles h3 {
    margin: 0 0 0.55rem;
    font-size: 1rem;
  }

  .principles p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.87rem;
    line-height: 1.55;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .tags span {
    padding: 0.42rem 0.72rem;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    background: var(--code-inline-bg);
    color: var(--text-muted);
    font: 0.79rem 'JetBrains Mono', monospace;
  }

  .links {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    background: var(--card-bg) !important;
  }

  .links h2 {
    margin-bottom: 0 !important;
  }

  .actions {
    display: flex;
    gap: 0.8rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .actions a {
    padding: 0.65rem 0.85rem;
    font-size: 0.9rem;
    font-weight: 600;
  }

  @media (max-width: 680px) {
    .principles {
      grid-template-columns: 1fr;
    }

    .links {
      display: block;
    }

    .actions {
      margin-top: 1.3rem;
    }
  }
</style>
