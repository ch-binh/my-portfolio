---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Me - Binh Pham Portfolio">
  <div class="contact-page">
    <header class="intro">
      <p class="label">Contact</p>
      <h1>Contact Me</h1>
      <p>
        Have a firmware question, a hardware problem to investigate, or an idea worth
        discussing? Send me a message and I will get back to you.
      </p>
    </header>

    <section class="email-card">
      <div>
        <p class="label">Primary channel</p>
        <h2>Email</h2>
        <p class="muted">Best for technical discussions and professional connections.</p>
      </div>
      <a href="mailto:pcbinh.3005@gmail.com?subject=Let's%20Connect" class="email-button">
        pcbinh.3005@gmail.com
      </a>
    </section>

    <section class="discussion">
      <p class="label">Topics</p>
      <h2>We can talk about</h2>
      <div class="topic-grid">
        <p><strong>Firmware debugging</strong><span>DMA, timing, interrupts, and peripheral behavior.</span></p>
        <p><strong>Embedded systems</strong><span>MCUs, RTOS architecture, drivers, and board bring-up.</span></p>
        <p><strong>Engineering exchange</strong><span>Technical learning, workflows, and practical experience.</span></p>
      </div>
    </section>

    <section class="profiles">
      <div>
        <p class="label">Details</p>
        <h2>Profiles</h2>
      </div>
      <div class="profile-actions">
        <a href="https://github.com/ch-binh" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://www.linkedin.com/in/pham-chau-binh/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .contact-page {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .intro {
    margin-bottom: 0.25rem;
  }

  .label {
    font: 500 0.72rem 'JetBrains Mono', monospace;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-color);
    margin-bottom: 0.7rem;
  }

  .intro h1 {
    margin-bottom: 1rem;
  }

  .intro > p:last-child {
    max-width: 620px;
    color: var(--text-muted);
    font-size: 1.04rem;
    line-height: 1.7;
    margin: 0;
  }

  .contact-page section {
    margin: 0;
    background: #fffdf9;
    border-color: var(--border-color);
  }

  .email-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    background: linear-gradient(145deg, #fffdf9 0%, #fbf4e7 100%) !important;
    padding: 2rem !important;
  }

  .email-card h2,
  .discussion h2,
  .profiles h2 {
    margin: 0 0 0.55rem;
    border: 0;
    padding: 0;
    font-size: 1.35rem;
  }

  .muted {
    color: var(--text-muted);
    margin: 0;
    font-size: 0.94rem;
  }

  .email-button {
    flex-shrink: 0;
    color: #fffdf9;
    background: var(--accent-color);
    padding: 0.8rem 1.15rem;
    border-radius: 8px;
    font-weight: 600;
  }

  .email-button:hover {
    color: #fffdf9;
    background: var(--accent-hover);
  }

  .discussion {
    padding: 2rem !important;
  }

  .profiles {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 2rem !important;
    background: linear-gradient(145deg, #fffdf9 0%, #fbf4e7 100%) !important;
  }

  .profiles h2 {
    margin-bottom: 0;
  }

  .profile-actions {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .profile-actions a {
    padding: 0.65rem 0.85rem;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1.4rem;
  }

  .topic-grid p {
    padding: 1.1rem;
    margin: 0;
    border: 1px solid rgba(122, 98, 70, 0.16);
    border-radius: 9px;
    background: #fbf4e7;
  }

  .topic-grid strong {
    display: block;
    margin-bottom: 0.45rem;
    font-size: 0.95rem;
  }

  .topic-grid span {
    color: var(--text-muted);
    font-size: 0.84rem;
    line-height: 1.55;
  }

  @media (max-width: 680px) {
    .email-card {
      display: block;
    }

    .email-button {
      display: block;
      margin-top: 1.5rem;
      text-align: center;
    }

    .topic-grid {
      grid-template-columns: 1fr;
    }

    .profiles {
      display: block;
    }

    .profile-actions {
      margin-top: 1.3rem;
    }
  }
</style>
