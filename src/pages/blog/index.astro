---
import Layout from '../../layouts/Layout.astro';
const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
---

<Layout title="Blog - Binh Pham Portfolio">
  <h1>Blog</h1>
  <p>Technical logs, notes, and tutorials on embedded programming:</p>

  <ul>
    <li>
      <a href={`${baseUrl}blog/pdm-vs-pcm/`}>PDM vs PCM in Embedded Audio</a>
    </li>
    <li>
      <a href={`${baseUrl}blog/calibrating-loadcells/`}>Calibrating Loadcells: Digital Noise Filtering in Embedded C</a>
    </li>
  </ul>
</Layout>