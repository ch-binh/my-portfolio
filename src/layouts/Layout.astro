---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  wide?: boolean;
  dark?: boolean;
  frontmatter?: {
    title: string;
    date?: string;
  };
}

const { title, wide = false, dark = false, frontmatter } = Astro.props;
const pageTitle = frontmatter?.title || title || "Saki - Portfolio";
const publishDate = frontmatter?.date;

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <!-- Premium Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <ClientRouter />
    <style is:global>
      :root {
        --bg-color: #FFF7E8;
        --text-color: #2A2621;
        --text-muted: #7A6246;
        --accent-color: #7A6246;
        --accent-hover: #B8895B;
        --border-color: rgba(122, 98, 70, 0.25);
        --card-bg: #FFFDF9;
        --code-bg: #1F1E1B;
        --code-inline-bg: #F5EEDB;
        --ease-expo: cubic-bezier(0.16, 1, 0.3, 1);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background-color: var(--bg-color);
        color: var(--text-color);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        line-height: 1.625;
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        padding: 2rem 1.5rem;
        transition:
          background-color 0.68s var(--ease-expo),
          color 0.52s var(--ease-expo);
      }

      body.dark {
        --bg-color: #070B10;
        --text-color: #E6EDF3;
        --text-muted: #8B98A5;
        --accent-color: #78DCE8;
        --accent-hover: #8AA4FF;
        --border-color: #1D2A36;
        --card-bg: #0D141C;
        --code-bg: #070B10;
        --code-inline-bg: #121C26;
      }

      /* Ease the palette shift between the dark landing page and light reading pages. */
      @keyframes page-blend-out {
        to {
          opacity: 0;
          filter: blur(1.5px);
        }
      }

      @keyframes page-blend-in {
        from {
          opacity: 0;
          filter: blur(1.5px);
        }
        to {
          opacity: 1;
          filter: blur(0);
        }
      }

      ::view-transition-old(root) {
        animation: page-blend-out 0.42s var(--ease-expo) both;
      }

      ::view-transition-new(root) {
        animation: page-blend-in 0.68s var(--ease-expo) both;
      }

      /* Premium Fade-In Page Transition */
      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      main {
        animation: fadeInUp 0.6s var(--ease-expo) both;
      }

      /* Premium Minimalist Container */
      .container {
        max-width: 720px;
        margin: 0 auto;
        padding-bottom: 5rem;
      }

      .container.wide {
        max-width: 1280px;
      }

      /* Navigation Header */
      header {
        margin-bottom: 3.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px dashed var(--border-color);
      }

      nav {
        display: flex;
        gap: 1.5rem;
        align-items: center;
      }

      nav a {
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 500;
        font-size: 0.95rem;
        transition: color 0.25s var(--ease-expo), border-color 0.25s var(--ease-expo);
        padding-bottom: 0.25rem;
        border-bottom: 2px solid transparent;
      }

      nav a:hover, nav a.active {
        color: var(--text-color);
      }

      nav a.active {
        border-color: var(--accent-color);
      }

      body.dark nav a.active {
        color: var(--accent-color);
      }

      /* Premium Markdown Styling */
      h1, h2, h3, h4, h5, h6 {
        color: var(--text-color);
        font-weight: 700;
        line-height: 1.25;
        margin-top: 2rem;
        margin-bottom: 1rem;
      }

      h1 {
        font-size: 2.25rem;
        margin-top: 0;
        margin-bottom: 1.5rem;
        letter-spacing: -0.025em;
      }

      h2 {
        font-size: 1.5rem;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 0.4rem;
        margin-top: 2.5rem;
        letter-spacing: -0.015em;
      }

      h3 {
        font-size: 1.25rem;
        margin-top: 2rem;
      }

      p {
        margin-bottom: 1.25rem;
        color: var(--text-color);
      }

      /* Premium Card Layout for Projects & Sections */
      section {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        transition: transform 0.3s var(--ease-expo), border-color 0.3s var(--ease-expo), box-shadow 0.3s var(--ease-expo);
      }

      section:hover {
        transform: translateY(-4px);
        border-color: var(--accent-color);
        box-shadow: 0 12px 30px -15px rgba(56, 189, 248, 0.15);
      }

      a {
        color: var(--accent-color);
        text-decoration: none;
        transition: color 0.25s var(--ease-expo), transform 0.25s var(--ease-expo);
        display: inline-block;
      }

      a:hover {
        color: var(--accent-hover);
        text-decoration: none;
        transform: translateY(-1px);
      }

      ul, ol {
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
      }

      li {
        margin-bottom: 0.5rem;
        transition: transform 0.25s var(--ease-expo);
      }

      li:hover {
        transform: translateX(4px);
      }

      li::marker {
        color: var(--accent-color);
      }

      /* Monospace & Code styling */
      code {
        font-family: 'JetBrains Mono', 'Fira Code', Consolas, Monaco, 'Andale Mono', monospace;
        font-size: 0.875em;
        background-color: var(--code-inline-bg);
        color: var(--text-color);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        border: 1px solid var(--border-color);
      }

      pre {
        background-color: var(--code-bg) !important;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1.25rem;
        overflow-x: auto;
        margin-bottom: 1.5rem;
      }

      pre code {
        background-color: transparent;
        padding: 0;
        border: none;
        border-radius: 0;
        font-size: 0.9em;
        color: inherit;
      }

      /* Date label */
      .post-meta {
        font-size: 0.9rem;
        color: var(--text-muted);
        margin-top: -1rem;
        margin-bottom: 2rem;
        display: flex;
        gap: 0.5rem;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 2rem;
        font-size: 0.9rem;
        color: var(--text-muted);
      }

      .back-link:hover {
        color: var(--accent-color);
        text-decoration: none;
      }

      /* Minimal Footer */
      footer {
        margin-top: 5rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border-color);
        font-size: 0.85rem;
        color: var(--text-muted);
        text-align: center;
      }

      @media (prefers-reduced-motion: reduce) {
        body {
          transition: none;
        }

        main,
        ::view-transition-old(root),
        ::view-transition-new(root) {
          animation: none;
        }
      }
    </style>
  </head>
  <body class:list={{ dark }}>
    <div class:list={['container', { wide }]}>
      <header>
        <nav>
          <a href={baseUrl} class="nav-home">Home</a>
          <a href={`${baseUrl}projects/`} class="nav-projects">Projects</a>
          <a href={`${baseUrl}blog/`} class="nav-blog">Notes</a>
          <a href={`${baseUrl}about/`} class="nav-about">About</a>
          <a href={`${baseUrl}contact/`} class="nav-contact">Contact</a>
        </nav>
      </header>

      <main>
        {publishDate && (
          <div class="post-meta">
            <time datetime={publishDate}>{new Date(publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          </div>
        )}
        <slot />
      </main>

      <footer>
        <p>&copy; {new Date().getFullYear()} Saki. Compiled successfully. Zero errors, zero warnings.</p>
      </footer>
    </div>

    <!-- Active Class Script -->
    <script define:vars={{ baseUrl }}>
      const currentPath = window.location.pathname;
      document.querySelectorAll('nav a').forEach(link => {
        const href = link.getAttribute('href');
        // Handle active states beautifully
        if (href === baseUrl) {
          if (currentPath === baseUrl || currentPath === baseUrl + 'index.html' || currentPath === baseUrl + 'index') {
            link.classList.add('active');
          }
        } else if (currentPath.startsWith(href)) {
          link.classList.add('active');
        }
      });
    </script>
  </body>
</html>
